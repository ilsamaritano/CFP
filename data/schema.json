{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CFP and Journal Call Schema",
  "description": "Schema for call for papers and journal calls dataset",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier for the call"
    },
    "title": {
      "type": "string",
      "description": "Title of the conference or journal"
    },
    "venue_type": {
      "type": "string",
      "enum": ["conference", "journal"],
      "description": "Type of venue"
    },
    "rank": {
      "type": "string",
      "enum": ["A*", "A", "B", "C", "Q1", "Q2", "Q3", "Q4", "unknown"],
      "description": "Ranking of the venue"
    },
    "area": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["MPC", "SEC"]
      },
      "description": "Research areas covered"
    },
    "topics": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Specific topics or tracks"
    },
    "deadline": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "Submission deadline in YYYY-MM-DD format"
    },
    "status": {
      "type": "string",
      "enum": ["open", "closed", "upcoming"],
      "description": "Current status of the call"
    },
    "official_url": {
      "type": "string",
      "format": "uri",
      "description": "Official URL of the conference or journal"
    },
    "source_url": {
      "type": "string",
      "format": "uri",
      "description": "Source URL where the call was found"
    },
    "last_checked": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "Date when the information was last verified"
    },
    "notes": {
      "type": "string",
      "description": "Additional notes or information"
    }
  },
  "required": [
    "id",
    "title",
    "venue_type",
    "rank",
    "area",
    "topics",
    "deadline",
    "status",
    "official_url",
    "source_url",
    "last_checked"
  ]
}
